ANTHROPIC_API_KEY=your_anthropic_api_key_here
# One or more SerpAPI free-tier keys (250 searches/mo each). The scraper rotates
# across them, falling back to the next when one hits its monthly cap. Add as many
# as you have: SERPAPI_KEY_1, SERPAPI_KEY_2, ... (a single legacy SERPAPI_KEY also works).
SERPAPI_KEY_1=your_first_serpapi_key_here
SERPAPI_KEY_2=your_second_serpapi_key_here
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here
